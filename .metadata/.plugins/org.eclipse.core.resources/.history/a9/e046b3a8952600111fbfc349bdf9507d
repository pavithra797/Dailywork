package banking.test;

import banking.exception.BankingException;
import banking.model.Account;
import banking.service.BankService;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;

import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.Mockito;

import static org.mockito.Mockito.*;
import static org.junit.jupiter.api.Assertions.*;
public class BankServiceTest {

    @InjectMocks
    private BankService bank;
    @Mock
    private Account mockAccount;

    @BeforeEach
    void setup() {
       
        bank = new BankService() {
            @Override
            public Account getAccount(int accNo) {
                if (accNo == 1) return mockAccount;
                throw new BankingException("Account not found");
            }
        };
    }

    @Test
    void testDepositWithMock() {
        when(mockAccount.getBalance()).thenReturn(1000.0);
        doNothing().when(mockAccount).deposit(500);

        bank.deposit(1, 500);
        verify(mockAccount).deposit(500);
        assertEquals(1000.0, bank.getAccount(1).getBalance());
    }

    @Test
    void testWithdrawWithMock() {
        when(mockAccount.getBalance()).thenReturn(1000.0);
        doNothing().when(mockAccount).withdraw(300);

        bank.withdraw(1, 300);

        verify(mockAccount).withdraw(300);
        assertEquals(1000.0, bank.getAccount(1).getBalance());
    }

    @Test
    void testWithdrawNegativeAmountWithMock() {
        doThrow(new BankingException("Withdrawal must be positive"))
                .when(mockAccount).withdraw(-50);

        assertThrows(BankingException.class, () -> bank.withdraw(1, -50));

        verify(mockAccount).withdraw(-50);
    }

    @Test
    void testDepositNegativeAmountWithMock() {
        doThrow(new BankingException("Deposit must be positive"))
                .when(mockAccount).deposit(-100);

        assertThrows(BankingException.class, () -> bank.deposit(1, -100));

        verify(mockAccount).deposit(-100);
    }

    @Test
    void testGetNonExistentAccountWithMock() {
        assertThrows(BankingException.class, () -> bank.getAccount(999));
    }
}