package lms;

public class Book {

	int id;
	String title;
	double price;
	String author;
	boolean reserved;

	public Book(int id, String title, double price, String author) {
		this.id = id;
		this.title = title;
		this.price = price;
		this.author = author;
		this.reserved = false;
	}

	public Book(String string, String title2, float price2, String author2) {
		// TODO Auto-generated constructor stub
	}

	@Override
	public String toString() {
		return """
				Book ID   : %d
				Title     : %s
				Author    : %s
				Price     : $%.2f
				---------------------------
				""".formatted(id, title, author, price);
	}
	 public String toCSV() {
	        return String.format("%d,%s,%s,%.2f", id, title, author, price);
	    }

}